name = "steady"
main = "worker/index.js"
compatibility_date = "2026-07-01"
compatibility_flags = ["nodejs_compat"]

# --- D1 database ---
# Create with: wrangler d1 create steady
# Then paste the returned database_id below.
[[d1_databases]]
binding = "DB"
database_name = "steady"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

# --- Daily cron: pushes due topics to Todoist ---
# Pick a UTC time that lands in your own morning — e.g. 23:30 UTC is
# 5:00 AM IST.
[triggers]
crons = ["30 23 * * *"]

# --- Static frontend, served by the same Worker ---
# run_worker_first: without this, Cloudflare serves static assets directly
# and never invokes fetch() for them — which would skip the Basic Auth
# check entirely for the frontend page itself.
[assets]
directory = "./public"
binding = "ASSETS"
run_worker_first = true

# --- Non-secret config ---
# Default destination project; individual topics can override this with
# their own todoist_project_id (see the picker in the frontend).
[vars]
TODOIST_PROJECT_ID = "REPLACE_WITH_TODOIST_PROJECT_ID"
# Means "there's a live outstanding revision task for this topic". Applied
# to every task Steady pushes, and added by the inbound importer (below)
# the moment it adopts a task — a task that already carries this label is
# already tracked and is never re-imported.
REVISION_LABEL = "review"
# The actual sync gate, both directions. Apply this label to any Todoist
# task, anywhere in your project tree, to have the daily cron import it as
# a new Steady topic (as long as it doesn't already carry REVISION_LABEL).
# Every task Steady pushes also carries this label, so any task linked to
# Steady — pushed or imported — can be found by this one label regardless
# of which direction touched it.
STEADY_LABEL = "steady"

# --- Secrets (do NOT put these in this file) ---
# wrangler secret put TODOIST_API_TOKEN
# wrangler secret put BASIC_AUTH_USER      # optional — gates the whole app
# wrangler secret put BASIC_AUTH_PASS
